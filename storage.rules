rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Global Safety Net: Default Deny All (avoids wide wildcard access)
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Course thumbnails (Cover images)
    match /courses/{courseId}/thumbnail/{fileName} {
      // Anyone can view course cover images
      allow read: if true;

      // Authenticated users can upload or modify course cover images.
      // This is the cleanest, most robust setup for apps using custom Firestore Database IDs,
      // where cross-service firestore lookup rules are restricted.
      allow write: if request.auth != null && 
        request.resource.contentType.matches('image/.*') && 
        request.resource.size < 5 * 1024 * 1024; // size < 5MB
    }

    // User profile avatars
    match /users/{userId}/avatar/{fileName} {
      // Anyone can view user profile avatars
      allow read: if true;

      // An authenticated user can upload their own profile avatar
      allow write: if request.auth != null && 
        request.auth.uid == userId && 
        request.resource.contentType.matches('image/.*') && 
        request.resource.size < 5 * 1024 * 1024; // size < 5MB
    }
  }
}
