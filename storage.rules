rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Global Safety Net: Default Deny All
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Course thumbnails (Cover images)
    match /courses/{courseId}/thumbnail/{fileName} {
      // Anyone can view course cover images
      allow read: if true;

      // Only verified admin/instructor can upload or modify course cover images.
      // We check the admin email directly. This avoids firestore cross-service lookup runtime errors.
      allow write: if request.auth != null && 
        request.auth.token.email == "ciuldinciuldin@gmail.com" && 
        request.resource.contentType.matches('image/.*') && 
        request.resource.size < 5 * 1024 * 1024; // size < 5MB
    }
  }
}
